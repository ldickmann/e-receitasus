# Variáveis de ambiente do frontend Flutter — E-ReceitaSUS
#
# COMO USAR:
#   1. Copie este arquivo para `.env` (não commitado) ou exporte como vars do shell
#   2. Use no comando flutter via --dart-define:
#
#      flutter run \
#        --dart-define=SUPABASE_URL=$SUPABASE_URL \
#        --dart-define=SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
#
#   3. Em CI/CD, configure como secrets do pipeline.
#
# IMPORTANTE:
#   - SUPABASE_ANON_KEY é a chave PUBLISHABLE (pública por design + RLS).
#   - Jamais coloque a service_role aqui — essa chave só pode existir no backend.

# URL do projeto Supabase (https://<ref>.supabase.co)
SUPABASE_URL=

# Chave anônima publicável (formato sb_publishable_... ou JWT eyJ...)
SUPABASE_ANON_KEY=
