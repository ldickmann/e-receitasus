# ============================================================
# Variáveis de ambiente do backend E-ReceitaSUS
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commite o .env com valores reais.
# ============================================================

# Banco de dados — Connection Pooling via PgBouncer (porta 6543)
DATABASE_URL="postgresql://usuario:senha@host:6543/postgres?pgbouncer=true"

# Banco de dados — Conexão direta para migrações Prisma (porta 5432)
DIRECT_URL="postgresql://usuario:senha@host:5432/postgres"

# JWT Secret do Supabase (Settings > API > JWT Secret no painel do Supabase)
SUPABASE_JWT_SECRET="<supabase-jwt-secret>"

# URL pública do projeto Supabase (usada para validação JWKS)
SUPABASE_URL="https://<ref>.supabase.co"

# Origens permitidas para CORS — separadas por vírgula, sem espaços.
# Em produção: liste apenas os domínios do frontend autorizado.
# Em desenvolvimento local com Flutter Web/desktop: adicione http://localhost:<porta>
# Exemplo: ALLOWED_ORIGINS=https://app.seudominio.com,http://localhost:3000
ALLOWED_ORIGINS=https://app.seudominio.com

# Porta do servidor HTTP (opcional — padrão: 3000)
# PORT=3000
