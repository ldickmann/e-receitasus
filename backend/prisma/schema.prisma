datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum ProfessionalType {
  MEDICO
  ENFERMEIRO
  FARMACEUTICO
  PSICOLOGO
  NUTRICIONISTA
  FISIOTERAPEUTA
  DENTISTA
  ASSISTENTE_SOCIAL
  ADMINISTRATIVO
  OUTROS
}

enum PrescriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model User {
  id                    String           @id @default(uuid())
  firstName             String?
  lastName              String?
  name                  String
  birthDate             DateTime?        @db.Date
  email                 String           @unique
  professionalType      ProfessionalType @default(ADMINISTRATIVO)
  professionalId        String?
  professionalState     String?
  specialty             String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  prescriptionsCreated  Prescription[]   @relation("PrescribedBy")
  prescriptionsReceived Prescription[]   @relation("PatientPrescriptions")

  @@index([professionalType])
  @@index([createdAt])
}

model Prescription {
  id          String             @id @default(uuid())
  medicine    String
  description String?
  doctorName  String?
  status      PrescriptionStatus @default(ACTIVE)

  patientId   String
  doctorId    String?

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  patient     User               @relation("PatientPrescriptions", fields: [patientId], references: [id], onDelete: Cascade)
  doctor      User?              @relation("PrescribedBy", fields: [doctorId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([status])
  @@index([createdAt])
}