// ==========================================
// CONFIGURAÇÃO DO BANCO DE DADOS (SUPABASE)
// ==========================================
datasource db {
  provider  = "postgresql"
  // URL para o modo de transação (Porta 6543) - Usada pela aplicação
  url       = env("DATABASE_URL")
  // URL para o modo de sessão (Porta 5432) - Usada para Migrations/Introspection
  directUrl = env("DIRECT_URL")
}

// ==========================================
// GERADOR DO CLIENTE PRISMA
// ==========================================
generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS (TIPOS ENUMERADOS)
// ==========================================

enum ProfessionalType {
  MEDICO
  ENFERMEIRO
  FARMACEUTICO
  PSICOLOGO
  NUTRICIONISTA
  FISIOTERAPEUTA
  DENTISTA
  ASSISTENTE_SOCIAL
  ADMINISTRATIVO
  OUTROS
}

enum PrescriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

// ==========================================
// MODELS (TABELAS DO BANCO DE DADOS)
// ==========================================

model User {
  id                 String           @id @default(uuid())
  name               String
  email              String           @unique
  password           String
  
  professionalType   ProfessionalType @default(ADMINISTRATIVO)
  professionalId     String?          // CRM, COREN, etc.
  professionalState  String?          // UF do conselho
  specialty          String?
  
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  // Relações
  prescriptionsCreated  Prescription[] @relation("PrescribedBy")
  prescriptionsReceived Prescription[] @relation("PatientPrescriptions")
}

model Prescription {
  id          String             @id @default(uuid())
  medicine    String
  description String?
  doctorName  String?            // Nome formatado para exibição rápida
  status      PrescriptionStatus @default(ACTIVE)

  // Chaves Estrangeiras
  patientId   String
  doctorId    String?

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  // Relações (Integridade Referencial)
  patient     User               @relation("PatientPrescriptions", fields: [patientId], references: [id], onDelete: Cascade)
  doctor      User?              @relation("PrescribedBy", fields: [doctorId], references: [id], onDelete: SetNull)

  // Índices para performance em consultas de larga escala
  @@index([patientId])
  @@index([status])
  @@index([createdAt])
}