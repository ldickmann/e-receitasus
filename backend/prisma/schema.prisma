datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum ProfessionalType {
  MEDICO
  ENFERMEIRO
  FARMACEUTICO
  PSICOLOGO
  NUTRICIONISTA
  FISIOTERAPEUTA
  DENTISTA
  ASSISTENTE_SOCIAL
  ADMINISTRATIVO
  OUTROS
  /// Usuário SUS que recebe receitas — não é profissional de saúde
  PACIENTE
}

/// Espelha o ciclo de vida de um pedido de renovação de prescrição.
/// Fluxo: PENDING_TRIAGE → TRIAGED → PRESCRIBED ou REJECTED.
/// Deve ser sincronizado com o enum RenewalStatus no Dart (frontend/lib/models/renewal_request_model.dart).
enum RenewalStatus {
  PENDING_TRIAGE
  TRIAGED
  PRESCRIBED
  REJECTED
}

model User {
  id                    String           @id @default(uuid())
  firstName             String?
  lastName              String?
  name                  String
  birthDate             DateTime?        @db.Date
  email                 String           @unique
  professionalType      ProfessionalType @default(ADMINISTRATIVO)
  professionalId        String?
  professionalState     String?
  specialty             String?

  /// Campos exclusivos do tipo PACIENTE — preenchidos apenas no cadastro de pacientes SUS

  /// Cartão Nacional de Saúde — máximo 15 caracteres
  cns                   String?
  /// CPF do paciente — 11 dígitos sem formatação
  cpf                   String?          @unique
  /// Nome Social — opcional, não substitui o nome civil nos documentos
  socialName            String?
  /// Nome completo da mãe ou, na ausência, do pai/responsável legal
  motherParentName      String?
  /// Cidade onde o paciente nasceu
  birthCity             String?
  /// UF de nascimento — 2 caracteres (ex: SC)
  birthState            String?          @db.Char(2)
  /// Sexo conforme declarado pelo paciente
  gender                String?
  /// Raça/Cor conforme classificação IBGE
  ethnicity             String?
  /// Estado civil do paciente
  maritalStatus         String?
  /// Celular com DDD — 11 dígitos (ex: 47988420692)
  phone                 String?
  /// Escolaridade do paciente
  education             String?
  /// CEP do endereço — 8 dígitos sem hífen
  zipCode               String?          @db.Char(8)
  /// Logradouro (rua, avenida etc.)
  street                String?
  /// Número do endereço
  streetNumber          String?
  /// Complemento opcional (apto, bloco etc.)
  complement            String?
  /// Bairro
  district              String?
  /// Cidade do endereço atual
  addressCity           String?
  /// UF do endereço atual — 2 caracteres
  addressState          String?          @db.Char(2)

  /// UBS (Unidade Básica de Saúde) à qual o usuário está vinculado.
  /// - Profissionais: vinculados manualmente (máx. 3 por UBS, regra de negócio).
  /// - Pacientes: atribuição automática pelo bairro via trigger
  ///   `auto_assign_patient_health_unit` no banco.
  healthUnitId          String?          @db.Uuid
  healthUnit            HealthUnit?      @relation(fields: [healthUnitId], references: [id], onDelete: SetNull)

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  // Receitas em si vivem na tabela BaaS `prescriptions` (snake_case),
  // acessada diretamente pelo Flutter via Supabase SDK. Sem relação Prisma
  // porque essa tabela usa FKs para `auth.users` (fora do schema Prisma).

  /// Pedidos de renovação onde este usuário é o paciente solicitante
  renewalRequestsAsPatient RenewalRequest[] @relation("PatientRenewalRequests")
  /// Pedidos de renovação atribuídos a este médico para emissão
  renewalRequestsAsDoctor  RenewalRequest[] @relation("DoctorRenewalRequests")
  /// Pedidos de renovação triados por este enfermeiro
  renewalRequestsAsNurse   RenewalRequest[] @relation("NurseRenewalRequests")

  @@index([professionalType])
  @@index([createdAt])
  @@index([cpf])
  @@index([healthUnitId])
}

/// Unidade Básica de Saúde — atende exatamente UM bairro de uma cidade.
/// Profissionais e pacientes são vinculados a uma única UBS.
/// Regra MVP: máximo de 3 profissionais por UBS (garantido por trigger
/// `enforce_max_professionals_per_unit` no banco).
model HealthUnit {
  id                String   @id @default(uuid()) @db.Uuid
  /// Nome humano da UBS (ex: "UBS Centro")
  name              String
  /// Bairro atendido — único dentro da mesma cidade
  district          String
  /// Cidade da UBS (MVP: sempre "Navegantes")
  city              String
  /// UF com 2 caracteres (MVP: sempre "SC")
  state             String   @db.Char(2)
  /// Limite máximo de profissionais vinculados (1–3)
  maxProfessionals  Int      @default(3) @map("max_professionals")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt       @map("updated_at")

  /// Usuários vinculados (profissionais e pacientes)
  users             User[]

  @@unique([district, city], name: "health_units_district_city_unique")
  @@index([district, city], map: "idx_health_units_district_city")
  @@map("health_units")
}

/// Representa um pedido de renovação de prescrição feito por um paciente.
/// Percorre o ciclo: PENDING_TRIAGE → TRIAGED → PRESCRIBED (ou REJECTED).
/// Os triggers de updated_at e block_duplicate_renewal ficam em
/// supabase/migrations/ pois são PL/pgSQL que o Prisma não modela.
model RenewalRequest {
  id String @id @default(uuid())

  /// FK para a prescrição original que será renovada.
  /// Aponta para a tabela BaaS `prescriptions` (lowercase) — FK
  /// gerenciada via SQL raw porque essa tabela não é modelada pelo Prisma.
  prescriptionId String @db.Uuid
  /// FK para o paciente solicitante (User.id = auth.users.id em texto)
  patientUserId  String
  /// Médico designado pelo enfermeiro; preenchido na transição TRIAGED
  doctorUserId   String?
  /// Enfermeiro responsável; preenchido ao aprovar ou rejeitar
  nurseUserId    String?

  status        RenewalStatus @default(PENDING_TRIAGE)

  /// Observações opcionais do paciente (limite de 500 chars tratado no app)
  patientNotes  String?
  /// Notas do enfermeiro; obrigatórias quando status = REJECTED (validação no app)
  nurseNotes    String?

  /// ID da nova prescrição emitida ao concluir o fluxo (soft ref, sem FK,
  /// pois a prescrição renovada pode ainda não existir no momento do update)
  renewedPrescriptionId String? @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Sem relação Prisma para a prescrição original — a tabela `prescriptions`
  // (BaaS) não é modelada aqui. A FK existe no banco via migration SQL.
  patient      User         @relation("PatientRenewalRequests", fields: [patientUserId], references: [id], onDelete: Cascade)
  doctor       User?        @relation("DoctorRenewalRequests", fields: [doctorUserId], references: [id], onDelete: SetNull)
  nurse        User?        @relation("NurseRenewalRequests", fields: [nurseUserId], references: [id], onDelete: SetNull)

  @@index([patientUserId])
  @@index([status])
  @@index([nurseUserId])
  @@index([doctorUserId])
  @@index([createdAt])
}